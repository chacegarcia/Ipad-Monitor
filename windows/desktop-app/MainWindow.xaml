<Window x:Class="PadLink.DesktopApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PadLink — Host"
        Height="420"
        Width="560"
        Loaded="OnLoaded"
        Closing="OnClosing">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Vertical" Grid.Row="0" Margin="0,0,0,12">
            <TextBlock FontSize="20" FontWeight="SemiBold" Text="PadLink Windows Host" />
            <TextBlock Margin="0,6,0,0" TextWrapping="Wrap"
                       Text="Prototype: TCP test pattern + protobuf session. IDD driver is separate (see windows/driver-idd)." />
        </StackPanel>

        <Border Grid.Row="1" BorderBrush="#DDD" BorderThickness="1" Padding="12" CornerRadius="4">
            <StackPanel>
                <TextBlock FontWeight="SemiBold" Text="Diagnostics" Margin="0,0,0,8" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Transport" />
                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="TransportText" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Resolution" Margin="0,4,0,0" />
                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="ResolutionText" Margin="0,4,0,0" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="FPS" Margin="0,4,0,0" />
                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="FpsText" Margin="0,4,0,0" />

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Encode latency (ms)" Margin="0,4,0,0" />
                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="EncodeText" Margin="0,4,0,0" />

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Decode latency (ms)" Margin="0,4,0,0" />
                    <TextBlock Grid.Row="4" Grid.Column="1" x:Name="DecodeText" Margin="0,4,0,0" />

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Input RTT (ms)" Margin="0,4,0,0" />
                    <TextBlock Grid.Row="5" Grid.Column="1" x:Name="RttText" Margin="0,4,0,0" />

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Last error" Margin="0,8,0,0" />
                    <TextBlock Grid.Row="6" Grid.Column="1" x:Name="ErrorText" TextWrapping="Wrap" Margin="0,8,0,0" />
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Window>
